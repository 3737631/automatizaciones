# ──────────────────────────
# Supabase (OBLIGATORIO)
# ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ──────────────────────────
# AI Provider (elegir uno)
# ──────────────────────────
# Opciones: openai | gemini | openrouter
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxx
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# ──────────────────────────
# Gmail OAuth (opcional)
# ──────────────────────────
GOOGLE_CLIENT_ID=xxxxx
GOOGLE_CLIENT_SECRET=xxxxx
GMAIL_REDIRECT_URI=https://tudominio.vercel.app/api/connect-email/callback

# ──────────────────────────
# Email (modo mock por defecto)
# ──────────────────────────
EMAIL_PROVIDER=mock
# Opciones: resend | smtp | gmail
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
